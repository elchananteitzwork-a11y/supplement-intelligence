NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
ANTHROPIC_API_KEY=sk-ant-api03-...
NEXT_PUBLIC_APP_URL=http://localhost:3000
RESEND_API_KEY=re_...

# Signal Engine — data providers (all optional; omit to use AI-only discovery)
# Keepa: Amazon product data — BSR, pricing, offer count, review velocity
# Get your key at https://keepa.com/#!api
# Cost: ~50 Keepa tokens per discovery call (category bestsellers + 10 products)
KEEPA_API_KEY=

# Reddit: community discussion volume, pain points, sentiment
# Reddit requires OAuth2 even for public read-only data (policy change 2023).
# Create a FREE "script" app in 2 minutes:
#   1. Go to https://www.reddit.com/prefs/apps
#   2. Click "Create another app" → type: script
#   3. Name: supplement-intelligence | redirect URI: http://localhost
#   4. Copy the client ID (14-char string under the app name)
#   5. Copy the secret
# Rate limit: 60 req/min (our usage: ~3 req per cache-miss discovery call)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=your_reddit_username

# Meta Ad Library (paid-media signal — ad count / advertiser count for a
# query, a revealed-economic-preference corroboration of demand) no longer
# uses a separate Meta token. Meta's own Ad Library API is scoped to
# political/social-issue ads only (confirmed against Meta's current
# documentation, 2026-07-13) — commercial ads were never in scope for it,
# for any app or verification level. This provider now scrapes the public
# Ad Library website via the Apify `apify/facebook-ads-scraper` actor
# instead, funded by APIFY_API_TOKEN below (same token already used by
# Manufacturing Intelligence and Competition signals — no separate
# credential needed). See lib/signal-engine/providers/meta-ads.ts.

# Escape hatches (set to "true" to disable a provider if it causes issues)
# GOOGLE_TRENDS_DISABLED=true
# TIKTOK_DISABLED=true
# REDDIT_DISABLED=true

# ── Apify — shared token across three providers ─────────────────────────────
# Manufacturing Intelligence (Xtracto Alibaba Products Search Scraper, Phase
# 2: live Alibaba supplier data — unit costs, MOQ, Trade Assurance, Gold
# Supplier; absent this key, falls back to AI-estimated values), Competition
# signal (junglee/amazon-crawler), and Meta Ads Library (apify/facebook-ads-
# scraper) all run on this one token — no separate credential per provider.
# 1. Create a free account at https://apify.com/sign-up
# 2. Get your Personal API token at https://console.apify.com/account/integrations
# Actor used: xtracto/alibaba-search-scraper (free tier: $5/month compute credits)
APIFY_API_TOKEN=

# ── Review Collection (Phase 5) ────────────────────────────────────────────
# Rainforest API: real-time Amazon reviews, pricing, and product data.
# Primary provider for the Review Intelligence Engine.
# Plans start at ~$49/month; free trial available.
# Get your key at: https://www.rainforestapi.com
# Without this key, the system falls back to the best-effort HTML scraper.
RAINFOREST_API_KEY=

# ── Billing (Stripe) — Roadmap item 8, Milestone 8 ──────────────────────────
# Absent any of these, /api/billing/* routes return 501 and do nothing —
# safe by default, same pattern as every other optional provider above.
#
# 1. Create a Stripe account (or use an existing one) at https://stripe.com
# 2. Create your Product(s)/Price(s) in the Stripe Dashboard — pricing,
#    tiers, and names are YOUR business decision; this codebase invents none
#    of them. On each Price (or its Product, as a fallback), add a metadata
#    key "analyses_limit" with a plain positive integer string value, e.g.
#    "50" — the webhook handler reads this to set the subscriber's
#    profiles.analyses_limit. No metadata = status updates but the limit is
#    left unchanged, never guessed (see lib/billing/webhook-handler.ts).
# 3. Get your secret key at https://dashboard.stripe.com/apikeys (use a
#    test-mode key — sk_test_... — until you've verified checkout, webhook
#    delivery, and portal flows end-to-end; switch to sk_live_... only when
#    ready to accept real payments).
STRIPE_SECRET_KEY=

# 4. Comma-separated allowlist of Price IDs this app is allowed to sell via
#    /api/billing/checkout. Required — the checkout route fails closed
#    (501) if this is unset, rather than trusting any client-supplied price
#    ID (this Stripe account may have unrelated Products).
STRIPE_ALLOWED_PRICE_IDS=

# 5. Create a webhook endpoint in the Stripe Dashboard (or via `stripe
#    listen` for local testing) pointing at {NEXT_PUBLIC_APP_URL}/api/billing/webhook,
#    subscribed to: checkout.session.completed, customer.subscription.created,
#    customer.subscription.updated, customer.subscription.deleted. Copy the
#    signing secret (whsec_...) here — every webhook request is verified
#    against this before any business logic runs.
STRIPE_WEBHOOK_SECRET=

# ── Science pipeline (PubMed + ClinicalTrials.gov) — Roadmap M2.5 ──────────
# Both real APIs are free and require no key. This nightly batch (Vercel
# Cron -> app/api/cron/science-pipeline, see vercel.json) is protected by a
# shared secret compared against the request's Authorization header —
# generate any random string (e.g. `openssl rand -hex 32`) and set the same
# value on Vercel's own auto-injected cron requests (Vercel adds this header
# automatically for its own Cron Jobs when this env var is set).
CRON_SECRET=

# Optional — raises PubMed's rate limit from 3 req/s to 10 req/s. Get a free
# key at https://www.ncbi.nlm.nih.gov/account/settings/ (NCBI account ->
# API Key Management). The pipeline works correctly without one.
PUBMED_API_KEY=

# ── Rate limiting (Upstash Redis) — Beta Readiness Audit (Critical) ────────
# Required in production. lib/rate-limit/ uses this to enforce per-user
# request limits across ALL serverless instances, not just the one that
# happened to handle a given request — the previous in-memory-only limiter
# could not do this. In any non-production environment (local `next dev`,
# tests), a lightweight in-memory limiter is used automatically instead —
# these two vars have no effect there.
#
# 1. Create a free database at https://console.upstash.com (Redis -> Create
#    Database — the free tier is more than enough for this app's volume).
# 2. Copy the REST URL and REST Token from the database's "REST API" tab.
# If these are unset (or Upstash is unreachable) in production, the limiter
# fails OPEN — requests are allowed through, unrated, with a logged warning
# — rather than taking down every metered route in the app. This protects
# paid-provider cost budgets, not authentication or billing; those fail
# CLOSED elsewhere in this codebase and are unaffected by this choice.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
