NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
ANTHROPIC_API_KEY=sk-ant-api03-...
NEXT_PUBLIC_APP_URL=http://localhost:3000
RESEND_API_KEY=re_...

# Signal Engine — data providers (all optional; omit to use AI-only discovery)
# Keepa: Amazon product data — BSR, pricing, offer count, review velocity
# Get your key at https://keepa.com/#!api
# Cost: ~50 Keepa tokens per discovery call (category bestsellers + 10 products)
KEEPA_API_KEY=

# Reddit: community discussion volume, pain points, sentiment
# Reddit requires OAuth2 even for public read-only data (policy change 2023).
# Create a FREE "script" app in 2 minutes:
#   1. Go to https://www.reddit.com/prefs/apps
#   2. Click "Create another app" → type: script
#   3. Name: supplement-intelligence | redirect URI: http://localhost
#   4. Copy the client ID (14-char string under the app name)
#   5. Copy the secret
# Rate limit: 60 req/min (our usage: ~3 req per cache-miss discovery call)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=your_reddit_username

# Escape hatches (set to "true" to disable a provider if it causes issues)
# GOOGLE_TRENDS_DISABLED=true
# TIKTOK_DISABLED=true
# REDDIT_DISABLED=true

# ── Review Collection (Phase 5) ────────────────────────────────────────────
# Rainforest API: real-time Amazon reviews, pricing, and product data.
# Primary provider for the Review Intelligence Engine.
# Plans start at ~$49/month; free trial available.
# Get your key at: https://www.rainforestapi.com
# Without this key, the system falls back to the best-effort HTML scraper.
RAINFOREST_API_KEY=
