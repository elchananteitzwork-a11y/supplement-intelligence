# Amazon Opportunity Hunter — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ──────────────────────────────────────────────
# KEEPA API KEY (required for Phase 1+)
# Get yours at: https://keepa.com/#!api
# Plans start at ~$19/month (Researcher tier)
# ──────────────────────────────────────────────
KEEPA_API_KEY=your_keepa_api_key_here

# ──────────────────────────────────────────────
# OPTIONAL: Cache TTL in hours (default: 24)
# Increase to reduce token usage during development.
# ──────────────────────────────────────────────
# KEEPA_CACHE_TTL_HOURS=24
